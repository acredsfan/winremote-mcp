{
	"servers": {
		"winremote": {
		"command": "python",
		"args": ["-m", "winremote", "--transport", "stdio"],
		"env": {}
		},
		"winremote-excel": {
		"command": "python",
		"args": ["-m", "winremote", "--transport", "stdio", "--profile", "excel"],
